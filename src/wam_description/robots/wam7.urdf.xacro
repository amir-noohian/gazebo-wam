<robot name="wam"
  xmlns:xacro="http://www.ros.org/wiki/xacro">

  <xacro:include filename="$(find wam_description)/models/wam_ros2_control.urdf.xacro"/>

  <!-- Includea all the WAM stuff -->
  <xacro:include filename="$(find wam_description)/models/wam_top.urdf.xacro"/>

  <!-- Root link is in the world frame-->
  <link name="world"/>

  <!-- 7-DOF Wam -->
  <xacro:wam_7dof prefix="wam" parent_link="world" xyz="0.0 0.0 1.0" rpy="0 0 0" />
  <xacro:wam_ros2_control prefix="wam"/>

</robot>
